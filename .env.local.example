# ─────────────────────────────────────────────────────────────────────────────
# AUSlotsRewards — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Base URL of this app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Session ──────────────────────────────────────────────────────────────────
# At least 32 random characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_me_with_a_32_plus_char_random_string

# ── Kick OAuth ───────────────────────────────────────────────────────────────
# Register your app at: https://kick.com/settings/developer
# Set the Redirect URI in the Kick dashboard to match KICK_REDIRECT_URI below.
KICK_CLIENT_ID=your_kick_client_id
KICK_CLIENT_SECRET=your_kick_client_secret
KICK_REDIRECT_URI=http://localhost:3000/api/auth/kick/callback
# Your Kick channel slug for live-status checks
NEXT_PUBLIC_KICK_CHANNEL=auslots

# ── Botrix Points System ─────────────────────────────────────────────────────
# Get your API key from the Botrix dashboard: https://botrix.live
BOTRIX_API_KEY=your_botrix_api_key
# Your Kick channel slug (lowercase, e.g. "auslots")
BOTRIX_CHANNEL=auslots
